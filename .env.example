#  Azure OpenAI — LLM 
MODEL_URL=
MODEL_KEY=

#  Azure OpenAI — Embedding
EMBED_URL=
EMBED_KEY=

#  Azure OpenAI — Vision
MULTI_MODAL_URL=
MULTI_MODAL_KEY=

#  Azure AI Search 
VECTORDB_URL=
VECTORDB_KEY=
VECTORDB_INDEX=sv-dev

DEBUG=false
# Max concurrent LLM evaluation calls (prevents Azure rate limit / connection drop on batch-multi)
MAX_CONCURRENT_EVALS=5

LLM_MODEL=gpt-5.4-mini
EMBED_MODEL=text-embedding-3-small

# Optional: override Azure AI Search field names 
# Set these if your index schema uses different field names than the defaults.
# Check: Azure Portal → Search Service → Indexes → <your-index> → Fields
# VECTORDB_FIELD_ID=id
# VECTORDB_FIELD_CONTENT=content
# VECTORDB_FIELD_SOURCE=source_file
# VECTORDB_FIELD_COURSE_CODE=courseCode
# VECTORDB_FIELD_VECTOR=content_vector

# Optional: override token prices (USD per 1M tokens)
PRICE_EMBED_INPUT=0.022
PRICE_EMBED_OUTPUT=0.0
PRICE_LLM_INPUT=0.75
PRICE_LLM_OUTPUT=4.50
PRICE_VISION_INPUT=2.50
PRICE_VISION_OUTPUT=10.0
